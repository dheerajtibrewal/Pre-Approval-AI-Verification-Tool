# Copy this file to .env and fill in real values. Never commit .env.
# See docs/limitations-and-assumptions.md for what each key is used for.

# OpenAI — used for form-field extraction, category disambiguation, and
# grounded per-criterion judgment calls (evaluation/llm_judge.py).
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o

# Firecrawl — primary fetch/render layer for provider websites (handles JS
# rendering + anti-bot bypass server-side, returns markdown + full-page
# screenshot in one call). See research/firecrawl_client.py.
FIRECRAWL_API_KEY=fc-replace-me

# Local server config
APP_HOST=127.0.0.1
APP_PORT=8000

# Where generated run artifacts (non-committed working runs) are written.
RUN_OUTPUT_DIR=output/runs
